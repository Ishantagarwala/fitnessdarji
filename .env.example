# ══════════════════════════════════════════════════════
# Fitness | दर्जी — environment variables
# Set these in: Vercel dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════════

# ── ZenMux AI (required for all AI features) ──────────
# Get your key at https://zenmux.ai
ZENMUX_API_KEY=your_zenmux_api_key_here

# ── Clerk Auth (required for login) ───────────────────
# Create a project at https://dashboard.clerk.com
# Then copy keys from: Clerk dashboard → API Keys

# Secret key — server-side only, NEVER expose in browser
CLERK_SECRET_KEY=sk_test_...

# Publishable key — also goes in index.html <meta name="clerk-pk">
# CLERK_PUBLISHABLE_KEY=pk_test_...   (not needed in env — it's in the HTML meta tag)

# ── Supabase (required for profile persistence) ───────
# Create a project at https://supabase.com
# Then copy keys from: Supabase dashboard → Settings → API

# Project URL (also safe to expose, but keep consistent)
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key — server-side only, NEVER expose in browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
